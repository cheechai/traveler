<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      <%= typeof title !== 'undefined' ? title + ' — Traveler' : 'Traveler ✈️'
      %>
    </title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Pacifico&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/app.css" />
  </head>
  <body class="min-h-screen bg-paper">
    <nav
      class="sticky top-0 z-50 bg-white border-b-2 border-gray-800 shadow-[0_2px_0px_#1f2937]"
    >
      <div
        class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between"
      >
        <a
          href="/trips"
          class="font-display text-2xl text-amber-500 hover:text-amber-600 transition-colors"
        >
          Traveler
        </a>
        <div class="flex items-center gap-3">
          <a href="/trips" class="btn-ghost text-sm">My Trips</a>
          <form action="/logout" method="POST" class="inline">
            <button type="submit" class="btn-ghost text-sm">Logout</button>
          </form>
        </div>
      </div>
    </nav>

    <% if (locals.success && locals.success.length) { %>
    <div class="max-w-5xl mx-auto px-4 mt-4" id="flash-success">
      <div
        class="bg-emerald-100 border-2 border-emerald-400 text-emerald-800 rounded-lg px-4 py-3 flex items-center justify-between"
      >
        <span><%= locals.success[0] %></span>
        <button
          onclick="document.getElementById('flash-success').remove()"
          class="text-emerald-600 hover:text-emerald-800 font-bold ml-4"
        >
          ×
        </button>
      </div>
    </div>
    <% } %> <% if (locals.error && locals.error.length) { %>
    <div class="max-w-5xl mx-auto px-4 mt-4" id="flash-error">
      <div
        class="bg-rose-100 border-2 border-rose-400 text-rose-800 rounded-lg px-4 py-3 flex items-center justify-between"
      >
        <span><%= locals.error[0] %></span>
        <button
          onclick="document.getElementById('flash-error').remove()"
          class="text-rose-600 hover:text-rose-800 font-bold ml-4"
        >
          ×
        </button>
      </div>
    </div>
    <% } %>

    <main class="max-w-5xl mx-auto px-4 py-8"><%- body %></main>

    <footer class="text-center py-8 text-gray-400 text-sm">
      Made with for adventures together
    </footer>

    <script src="/js/app.js"></script>
  </body>
</html>
