<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' — Traveler' : 'Traveler ✈️' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/app.css" />
</head>
<body style="min-height:100vh; background-color:#EBF5EE; background-image:radial-gradient(circle, #9BB5A8 1px, transparent 1px); background-size:24px 24px; font-family:'Inter',sans-serif; color:#283044;">

  <nav id="main-nav" style="background-color:#EBF5EE; position:sticky; top:0; z-index:50; transition:box-shadow 0.2s;">
    <div style="max-width:960px; margin:0 auto; padding:0.65rem 1.2rem; display:flex; align-items:center; justify-content:space-between;">
      <a href="/trips" style="font-family:'Pacifico',cursive; font-size:1.55rem; color:#283044; text-decoration:none; display:flex; align-items:center; gap:0.4rem; letter-spacing:0.01em;">
        Traveler
      </a>
      <div style="display:flex; align-items:center; gap:0.5rem;">
        <a href="/trips" style="font-family:'Inter',sans-serif; font-weight:500; font-size:0.875rem; color:#283044; background:rgba(40,48,68,0.07); padding:0.3rem 0.85rem; border-radius:8px; text-decoration:none; transition:background 0.15s;" onmouseover="this.style.background='rgba(40,48,68,0.13)'" onmouseout="this.style.background='rgba(40,48,68,0.07)'">My Trips</a>
        <form action="/logout" method="POST" style="display:inline;">
          <button type="submit" style="font-family:'Inter',sans-serif; font-weight:500; font-size:0.875rem; color:#283044; background:rgba(40,48,68,0.07); padding:0.3rem 0.85rem; border-radius:8px; border:none; cursor:pointer; transition:background 0.15s;" onmouseover="this.style.background='rgba(40,48,68,0.13)'" onmouseout="this.style.background='rgba(40,48,68,0.07)'">Logout</button>
        </form>
      </div>
    </div>
  </nav>
  <script>
    (function() {
      var nav = document.getElementById('main-nav');
      window.addEventListener('scroll', function() {
        if (window.scrollY > 4) {
          nav.style.boxShadow = '0 2px 12px rgba(40,48,68,0.13)';
        } else {
          nav.style.boxShadow = 'none';
        }
      }, { passive: true });
    })();
  </script>

  <% if (locals.success && locals.success.length) { %>
    <div style="max-width:960px; margin:1rem auto 0; padding:0 1.2rem;" id="flash-success">
      <div style="background:#d4edda; border:1.5px solid #78A1BB; border-radius:8px; padding:0.6rem 1rem; display:flex; align-items:center; justify-content:space-between; font-family:'Inter',sans-serif; font-size:0.9rem; color:#283044;">
        <span><%= locals.success[0] %></span>
        <button onclick="document.getElementById('flash-success').remove()" style="background:none;border:none;cursor:pointer;font-size:1.1rem;color:#8B786D;">×</button>
      </div>
    </div>
  <% } %>
  <% if (locals.error && locals.error.length) { %>
    <div style="max-width:960px; margin:1rem auto 0; padding:0 1.2rem;" id="flash-error">
      <div style="background:#fde8e8; border:1.5px solid #c97d7d; border-radius:8px; padding:0.6rem 1rem; display:flex; align-items:center; justify-content:space-between; font-family:'Inter',sans-serif; font-size:0.9rem; color:#283044;">
        <span><%= locals.error[0] %></span>
        <button onclick="document.getElementById('flash-error').remove()" style="background:none;border:none;cursor:pointer;font-size:1.1rem;color:#8B786D;">×</button>
      </div>
    </div>
  <% } %>

  <main style="max-width:960px; margin:0 auto; padding:2rem 1.2rem;">
